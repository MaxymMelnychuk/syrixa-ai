# Copy this file to `.env` and fill in real values. Never commit `.env`.

# HTTP port for `server.js` (default 3000).
PORT=3000

# Required: OpenRouter API key from https://openrouter.ai/keys
# Chat completions and embeddings both use this key.
OPENROUTER_API_KEY=your-api-key-here

# Model id on OpenRouter (chat). Embedding model is configured in `rag.js`.
# Examples: openai/gpt-4o-mini, anthropic/claude-3-haiku
OPENROUTER_MODEL=openai/gpt-4o-mini
